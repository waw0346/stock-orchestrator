OPENDART_API_KEY=replace_with_your_opendart_api_key
FISCAL_AI_API_KEY=replace_with_your_fiscal_ai_api_key
KIWOOM_APP_KEY=replace_with_your_kiwoom_app_key
KIWOOM_APP_SECRET=replace_with_your_kiwoom_app_secret
KIWOOM_ACCESS_TOKEN=
KIWOOM_BASE_URL=https://api.kiwoom.com
# Optional: absolute path to your Obsidian vault root (e.g. C:\Users\you\obsidian)
# If unset, scripts fall back to <project_root>/obsidian/
OBSIDIAN_VAULT_PATH=

# Optional: ClaudeSlim 로컬 프록시 (토큰 60~85% 절감)
# 사용 방법: 먼저 .\scripts\start_claudeslim.ps1 실행 후 아래 줄 활성화
# ANTHROPIC_BASE_URL=http://localhost:8086
